# 直播小幫手 — 水平擴展部署連線設定範例（計畫 §6.1）
# 複製為 .env 並填入實際值；.env 已列入 .gitignore，切勿提交。
#
# 外部基礎設施 = 主機埠口；容器內用 host.docker.internal 連回主機（或填主機區網 IP）。
# 埠口（3306/6379/5672）換成你主機實際對外映射的埠口。

# ── 外部服務連線 ──
MYSQL_CONNECTION_STRING=server=host.docker.internal;port=3306;database=discord_stream_bot;user=stream_bot;password=CHANGE_ME
REDIS_OPTION=host.docker.internal:6379,password=CHANGE_ME,syncTimeout=3000
RABBITMQ_HOST=host.docker.internal
RABBITMQ_PORT=5672
RABBITMQ_USER=bot
RABBITMQ_PASSWORD=CHANGE_ME
RABBITMQ_VHOST=/

# ── 叢集 ──
# TOTAL_SHARDS 必須與 docker-compose.yml 內 notifier-N 服務數量、各 command 的 total 一致
TOTAL_SHARDS=4

# ── 機密 Token（亦可改放 bot_config.json）──
DISCORD_TOKEN=CHANGE_ME
GOOGLE_API_KEY=CHANGE_ME

# 備註：以下設定無對應環境變數，請放在 bot_config.json：
#   RedisTokenKey（與後端共用，務必設定）、WebHookUrl、ApiServerDomain、
#   GoogleClientId/Secret、TwitCasting*/Twitch* 等。
